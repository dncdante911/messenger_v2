# ============================================================
# WorldMates Messenger — Node.js Server Environment Variables
# Скопіюйте цей файл у .env і заповніть своїми значеннями.
# ============================================================

# ── База даних MySQL (WoWonder) ──────────────────────────────
DB_HOST=localhost
DB_USER=social
DB_PASS=your_db_password_here
DB_NAME=socialhub

# ── Сайт ────────────────────────────────────────────────────
SITE_URL=https://worldmates.club
SITE_PATH=/var/www/www-root/data/www/worldmates.club

# ── WoWonder Purchase Code ───────────────────────────────────
PURCHASE_CODE=your_purchase_code_here

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ── TURN / Coturn credentials secret ────────────────────────
# Цей секрет використовується для генерації HMAC TURN credentials.
# Має збігатись з use-auth-secret + static-auth-secret у turnserver.conf
TURN_SECRET=your_turn_static_secret_here

# ── Шифрування повідомлень (AES-256-GCM) ────────────────────
# 32 байти у hex (64 символи). Генерація: openssl rand -hex 32
MSG_ENCRYPTION_KEY=your_64_char_hex_key_here

# ── Внутрішні IP адреси (для Redis/DB підключення) ──────────
# NODE_INTERNAL_HOST=192.168.0.250
# EXTERNAL_IP_1=195.22.131.11
# EXTERNAL_IP_2=46.232.232.38
