# ============================================================
# WorldMates Messenger — Node.js Server Environment Variables
# Скопіюйте цей файл у .env і заповніть своїми значеннями.
# ============================================================

# ── База даних MySQL (WoWonder) ──────────────────────────────
DB_HOST=localhost
DB_USER=social
DB_PASS=your_db_password_here
DB_NAME=socialhub

# ── Сайт ────────────────────────────────────────────────────
SITE_URL=https://worldmates.club
SITE_PATH=/var/www/www-root/data/www/worldmates.club

# ── WoWonder Purchase Code ───────────────────────────────────
PURCHASE_CODE=your_purchase_code_here

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ── TURN / Coturn credentials secret ────────────────────────
# Цей секрет використовується для генерації HMAC TURN credentials.
# Має збігатись з use-auth-secret + static-auth-secret у turnserver.conf
TURN_SECRET=your_turn_static_secret_here

# ── Шифрування повідомлень (AES-256-GCM) ────────────────────
# 32 байти у hex (64 символи). Генерація: openssl rand -hex 32
MSG_ENCRYPTION_KEY=your_64_char_hex_key_here

# ── SMTP для відправки OTP / відновлення паролю ─────────────
# Облікові дані SMTP (НЕ зберігати у коді — тільки тут)
SMTP_USER=support@worldmates.club
SMTP_PASS=your_smtp_password_here

# ── Rate limiter — кількість довірених проксі ───────────────
# Встановіть 1 якщо перед Node стоїть рівно один nginx/apache
TRUSTED_PROXY_COUNT=1

# ── Підписка PRO (Way4Pay) ───────────────────────────────────
# Отримати в кабінеті Way4Pay: https://cabinet.wayforpay.com
WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_account_here
WAYFORPAY_MERCHANT_SECRET=your_merchant_secret_here
WAYFORPAY_MERCHANT_DOMAIN=worldmates.club

# ── Підписка PRO (LiqPay) ────────────────────────────────────
# Отримати в кабінеті LiqPay: https://www.liqpay.ua/uk/adminbusiness
LIQPAY_PUBLIC_KEY=your_liqpay_public_key_here
LIQPAY_PRIVATE_KEY=your_liqpay_private_key_here

# ── Підписка PRO (Monobank Merchant) ────────────────────────
# Отримати токен: https://api.monobank.ua/ → Merchant → Підключення
MONOBANK_TOKEN=your_monobank_merchant_token_here
# Опціонально: секрет для верифікації webhook-підпису (X-Sign header)
# MONOBANK_WEBHOOK_SECRET=your_monobank_webhook_secret_here

# ── Ціна підписки PRO ────────────────────────────────────────
# Базова ціна за 1 місяць у гривнях (за замовчуванням 149)
SUBSCRIPTION_PRICE_UAH=149

# ── Перекладач повідомлень ───────────────────────────────────
# Google Cloud Translate v2 API key:
#   https://console.cloud.google.com/apis/credentials → Create API Key
#   Увімкніть API: Cloud Translation API
# GOOGLE_TRANSLATE_KEY=your_google_translate_api_key_here

# DeepL API key (безкоштовний або Pro):
#   https://www.deepl.com/uk/pro-api → Free API / Pro API
# DEEPL_API_KEY=your_deepl_api_key_here
# URL для DeepL: Free tier (за замовчуванням): https://api-free.deepl.com
#               Pro tier:                     https://api.deepl.com
# DEEPL_API_URL=https://api-free.deepl.com

# ── Внутрішні IP адреси (для Redis/DB підключення) ──────────
# NODE_INTERNAL_HOST=192.168.0.250
# EXTERNAL_IP_1=195.22.131.11
# EXTERNAL_IP_2=46.232.232.38
