<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Android 12+ Splash Screen API theme -->
    <style name="Theme.WorldMates.Starting" parent="Theme.SplashScreen">
        <!-- Window background: light gradient (drawable) -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <!-- Centered logo (must be 288×288 dp area; safe 192×192) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <!-- Optional: extend duration for the icon animation (ms, max 1000) -->
        <item name="windowSplashScreenAnimationDuration">600</item>
        <!-- Branding image at bottom (optional) -->
        <item name="android:windowSplashScreenBrandingImage" tools:targetApi="31">@drawable/splash_branding</item>
        <!-- After splash -->
        <item name="postSplashScreenTheme">@style/Theme.WorldMatesMessenger</item>
    </style>

</resources>
